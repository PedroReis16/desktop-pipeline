<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project>
  <PropertyGroup>
    <Platform>x64</Platform>
    <PublishDir>bin\x64\$(Configuration)\net10.0\publish</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained> <!--Instaladas as dependencias de runtime-->
    <PublishSingleFile>false</PublishSingleFile> <!--Quando true, publica todas as dependencias em um unico arquivo-->
    <PublishReadyToRun>true</PublishReadyToRun> <!--Melhora a performance do aplicativo publicado-->
    <PublishTrimmed>false</PublishTrimmed> <!--Remove assemblies não utilizadas para reduzir o tamanho do aplicativo publicado-->
  </PropertyGroup>
</Project>