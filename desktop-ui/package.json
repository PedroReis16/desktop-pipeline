{
  "name": "desktop-ui",
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron:serve": "concurrently -k -n NG,ELECTRON -c green,blue \"npm run start\" \"wait-on tcp:127.0.0.1:4200 && cross-env NODE_ENV=development electron .\"",
    "electron:start": "ng build --base-href ./ && electron .",
    "electron:build": "ng build --base-href ./ && electron-builder"
  },
  "private": true,
  "packageManager": "npm@11.17.0",
  "build": {
    "appId": "com.desktoppipeline.desktop-ui",
    "productName": "Desktop UI",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/desktop-ui/browser/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.10"
  }
}
